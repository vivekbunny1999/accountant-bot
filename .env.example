# Backend
DATABASE_URL=sqlite:///./accountant_bot.db
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
PLAID_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret_or_fernet_key
SESSION_TTL_DAYS=30

# Plaid Sandbox
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_sandbox_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional for OAuth/webhook flows later:
# PLAID_REDIRECT_URI=
# PLAID_WEBHOOK_URL=

# Optional deploy notes:
# For staging Postgres, use a URL like:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
