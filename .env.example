# Backend
DATABASE_URL=sqlite:///./accountant_bot.db
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
FRONTEND_URL=
# Optional regex for Vercel preview URLs, for example:
# CORS_ORIGIN_REGEX=https://your-project-.*\\.vercel\\.app
CORS_ORIGIN_REGEX=
PLAID_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret_or_fernet_key
SESSION_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30
CORS_ALLOW_ALL=false

# Safe beta gating
# open = anybody can sign up
# allowlist = only emails listed in BETA_ALLOWED_EMAILS can sign up
# closed = signup disabled
BETA_SIGNUP_MODE=allowlist
BETA_ALLOWED_EMAILS=founder@example.com,trust1@example.com,trust2@example.com
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_PASSWORD_RESET_DELIVERY=manual_beta
AUTH_PASSWORD_RESET_DEBUG_LINKS=false

# Plaid Sandbox
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_sandbox_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional for OAuth/webhook flows later:
# PLAID_REDIRECT_URI=
# PLAID_WEBHOOK_URL=

# Optional deploy notes:
# For staging Postgres, use a URL like:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
